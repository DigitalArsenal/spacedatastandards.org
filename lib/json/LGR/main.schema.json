{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "definitions": {
    "licensingWrappedKeyAlgorithm" : {
      "type" : "string",
      "enum": ["X25519_HKDF_SHA256_AES_256_GCM"]
    },
    "LWK" : {
      "type" : "object",
      "description" : "Wrapped module content key",
      "properties" : {
        "REQUEST_ID" : {
                "type" : "string",
                "description" : "Unique request identifier"
              },
        "MODULE_ID" : {
                "type" : "string",
                "description" : "Canonical module identifier"
              },
        "MODULE_VERSION" : {
                "type" : "string",
                "description" : "Optional module version"
              },
        "CONTENT_KEY_ID" : {
                "type" : "string",
                "description" : "Provider-local content key identifier"
              },
        "RECIPIENT_KEY_ID" : {
                "type" : "string",
                "description" : "Recipient key identifier or fingerprint"
              },
        "ALGORITHM" : {
                "$ref" : "#/definitions/licensingWrappedKeyAlgorithm",
                "description" : "Wrapped-key algorithm"
              },
        "REQUESTER_EPHEMERAL_PUBKEY" : {
                "type" : "array", "items" : {"type" : "integer", "minimum" : 0, "maximum" :255},
                "description" : "Requester ephemeral X25519 public key"
              },
        "PROVIDER_EPHEMERAL_PUBKEY" : {
                "type" : "array", "items" : {"type" : "integer", "minimum" : 0, "maximum" :255},
                "description" : "Provider ephemeral X25519 public key"
              },
        "HKDF_SALT" : {
                "type" : "array", "items" : {"type" : "integer", "minimum" : 0, "maximum" :255},
                "description" : "HKDF salt"
              },
        "IV" : {
                "type" : "array", "items" : {"type" : "integer", "minimum" : 0, "maximum" :255},
                "description" : "AES-GCM IV"
              },
        "CIPHERTEXT" : {
                "type" : "array", "items" : {"type" : "integer", "minimum" : 0, "maximum" :255},
                "description" : "Wrapped key ciphertext"
              },
        "TAG" : {
                "type" : "array", "items" : {"type" : "integer", "minimum" : 0, "maximum" :255},
                "description" : "AES-GCM authentication tag"
              },
        "EXPIRES_AT" : {
                "type" : "integer", "minimum" : 0, "maximum" : 18446744073709551615,
                "description" : "Envelope expiration time in milliseconds since epoch"
              }
      },
      "required" : ["REQUEST_ID", "MODULE_ID"],
      "additionalProperties" : false
    }
  },
  "$ref" : "#/definitions/LWK"
}
