{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "definitions": {
    "entityKind" : {
      "type" : "string",
      "enum": ["ENTITY", "SPACE", "GROUND", "AIRCRAFT", "MISSILE", "SHIP", "VEHICLE", "SENSOR", "OTHER"]
    },
    "ETM" : {
      "type" : "object",
      "description" : "Entity Metadata — generic queryable metadata for a host-local entity.\nParticipates in shared FlatSQL/WASM runtimes where multiple plugins\ncross-query the same entity collection.",
      "properties" : {
        "ENTITY_ID" : {
                "type" : "string",
                "description" : "Stable host-local entity identifier."
              },
        "NAME" : {
                "type" : "string",
                "description" : "Human-readable entity name used for shared query/search surfaces."
              },
        "KIND" : {
                "$ref" : "#/definitions/entityKind",
                "description" : "Broad entity category."
              },
        "SUBTYPE" : {
                "type" : "string",
                "description" : "More specific runtime subtype or class name."
              },
        "PARENT_ENTITY_ID" : {
                "type" : "string",
                "description" : "Optional parent entity id for hierarchy / linkage queries."
              },
        "WASM_HANDLE" : {
                "type" : "integer", "minimum" : 0, "maximum" : 4294967295,
                "description" : "Collection-scoped WASM handle used for batch visibility application."
              },
        "NORAD_CAT_ID" : {
                "type" : "integer", "minimum" : 0, "maximum" : 4294967295,
                "description" : "Optional NORAD catalog id for standards-backed entities."
              },
        "OBJECT_NAME" : {
                "type" : "string",
                "description" : "Primary object name surfaced by attached standards metadata."
              },
        "OBJECT_ID" : {
                "type" : "string",
                "description" : "Primary international / object designator surfaced by attached standards metadata."
              },
        "CAT_OBJECT_NAME" : {
                "type" : "string",
                "description" : "Secondary CAT object name when different from the primary object name."
              },
        "CAT_OBJECT_ID" : {
                "type" : "string",
                "description" : "Secondary CAT object id when different from the primary object id."
              },
        "FACILITY_TYPE" : {
                "type" : "string",
                "description" : "Ground / facility subtype metadata for non-space entity search."
              },
        "SEARCH_TEXT" : {
                "type" : "string",
                "description" : "Pre-normalized phrase-search text for collection-wide shared queries."
              },
        "OWNER" : {
                "type" : "string",
                "description" : "CAT owner country code."
              },
        "STATUS_CODE" : {
                "type" : "string",
                "description" : "CAT operational status code."
              },
        "LAUNCH_DATE" : {
                "type" : "string",
                "description" : "CAT launch date."
              },
        "LAUNCH_YEAR" : {
                "type" : "string",
                "description" : "Launch year derived from launch date."
              },
        "ORBIT_REGIME" : {
                "type" : "string",
                "description" : "Derived orbit regime classification."
              },
        "PERIOD" : {
                "type" : "number",
                "description" : "Orbital period in minutes."
              },
        "INCLINATION" : {
                "type" : "number",
                "description" : "Inclination in degrees."
              },
        "APOGEE" : {
                "type" : "number",
                "description" : "Apogee altitude in kilometers."
              },
        "PERIGEE" : {
                "type" : "number",
                "description" : "Perigee altitude in kilometers."
              },
        "MEAN_MOTION" : {
                "type" : "number",
                "description" : "Mean motion in revolutions per day."
              },
        "ECCENTRICITY" : {
                "type" : "number",
                "description" : "Orbital eccentricity."
              },
        "BSTAR" : {
                "type" : "number",
                "description" : "B* drag term from OMM."
              },
        "HAS_GP" : {
                "type" : "boolean",
                "description" : "Whether GP / OMM state is present for the entity."
              },
        "RESERVED" : {
                "type" : "array", "items" : {"type" : "integer", "minimum" : 0, "maximum" :255},
                "description" : "Reserved for forward-compatible growth."
              }
      },
      "additionalProperties" : false
    }
  },
  "$ref" : "#/definitions/ETM"
}
