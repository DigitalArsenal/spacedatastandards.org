{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "definitions": {
    "viewerMapMode" : {
      "type" : "string",
      "enum": ["UNKNOWN", "GEOGRAPHICAL_DAY_NIGHT", "GEOGRAPHICAL_CONSTANT", "POLITICAL"]
    },
    "viewerCameraFrameMode" : {
      "type" : "string",
      "enum": ["DEFAULT", "RADIAL_INTRACK", "CROSSTRACK_INTRACK", "RADIAL_CROSSTRACK"]
    },
    "viewerSatelliteAlignmentMode" : {
      "type" : "string",
      "enum": ["UNKNOWN", "ORBITAL", "NADIR"]
    },
    "VSTCameraRotation" : {
      "type" : "object",
      "description" : "Camera rotation offset. Quaternions are preferred when present; Euler\nangles are retained for import of older scenario JSON.",
      "properties" : {
        "YAW_DEG" : {
                "type" : "number"
              },
        "PITCH_DEG" : {
                "type" : "number"
              },
        "ROLL_DEG" : {
                "type" : "number"
              },
        "QUATERNION_X" : {
                "type" : "number"
              },
        "QUATERNION_Y" : {
                "type" : "number"
              },
        "QUATERNION_Z" : {
                "type" : "number"
              },
        "QUATERNION_W" : {
                "type" : "number"
              },
        "USES_QUATERNION" : {
                "type" : "boolean"
              }
      },
      "additionalProperties" : false
    },
    "VSTDisplaySettings" : {
      "type" : "object",
      "description" : "App display toggles for a scenario viewer.",
      "properties" : {
        "MAP_MODE" : {
                "$ref" : "#/definitions/viewerMapMode"
              },
        "SHOW_GEO_BELT_MARKERS" : {
                "type" : "boolean"
              },
        "SHOW_CIS_LUNAR" : {
                "type" : "boolean"
              },
        "SHOW_EQUATOR" : {
                "type" : "boolean"
              },
        "SHOW_LATITUDE" : {
                "type" : "boolean"
              },
        "SHOW_LONGITUDE" : {
                "type" : "boolean"
              },
        "SHOW_SHADOW_CONES" : {
                "type" : "boolean"
              },
        "SHOW_GIF_CONTROLS" : {
                "type" : "boolean"
              },
        "SHOW_ATMOSPHERE" : {
                "type" : "boolean"
              },
        "SHOW_SUN_DIRECTION_INDICATOR" : {
                "type" : "boolean"
              },
        "USE_STARFIELD" : {
                "type" : "boolean"
              },
        "USE_STITCHED_ORBIT" : {
                "type" : "boolean"
              }
      },
      "additionalProperties" : false
    },
    "VSTCameraOptions" : {
      "type" : "object",
      "description" : "Camera options for a space-domain scenario viewer.",
      "properties" : {
        "CAMERA_FRAME_MODE" : {
                "$ref" : "#/definitions/viewerCameraFrameMode"
              },
        "SATELLITE_ALIGNMENT" : {
                "$ref" : "#/definitions/viewerSatelliteAlignmentMode"
              },
        "DISTANCE_FROM_TARGET_KM" : {
                "type" : "number"
              },
        "ROTATION" : {
                "$ref" : "#/definitions/VSTCameraRotation"
              }
      },
      "additionalProperties" : false
    },
    "VST" : {
      "type" : "object",
      "description" : "Viewer State — display and camera state associated with a scenario.",
      "properties" : {
        "CAMERA" : {
                "$ref" : "#/definitions/VSTCameraOptions"
              },
        "DISPLAY_SETTINGS" : {
                "$ref" : "#/definitions/VSTDisplaySettings"
              },
        "FOCUSED_REFERENCE_ID" : {
                "type" : "string"
              },
        "FOCUSED_REFERENCE_INDEX" : {
                "type" : "integer", "minimum" : -2147483648, "maximum" : 2147483647
              }
      },
      "additionalProperties" : false
    }
  },
  "$ref" : "#/definitions/VST"
}
