{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "definitions": {
    "accessCategory" : {
      "type" : "string",
      "enum": ["OneTime", "Subscription", "Streaming", "Query"]
    },
    "paymentMethod" : {
      "type" : "string",
      "enum": ["Crypto_ETH", "Crypto_SOL", "Crypto_BTC", "SDN_Credits", "Fiat_Stripe", "Free", "UsageBased", "Enterprise"]
    },
    "listingCategory" : {
      "type" : "string",
      "enum": ["DataStream", "WasmModule"]
    },
    "GrantFieldStreamPolicy" : {
      "type" : "object",
      "description" : "Field-level stream policy bound into protected delivery and grants.",
      "properties" : {
        "POLICY_ID" : {
                "type" : "string"
              },
        "POLICY_VERSION" : {
                "type" : "integer", "minimum" : 0, "maximum" : 4294967295
              },
        "STREAM_ID" : {
                "type" : "string"
              },
        "SCHEMA_CODE" : {
                "type" : "string"
              },
        "ALLOWED_FIELD_PATHS" : {
                "type" : "array", "items" : {"type" : "string"}
              },
        "REDACTED_FIELD_PATHS" : {
                "type" : "array", "items" : {"type" : "string"}
              },
        "KEY_EPOCH" : {
                "type" : "string"
              },
        "GRANT_SCOPE" : {
                "type" : "string"
              },
        "ALLOWED_OPERATIONS" : {
                "type" : "array", "items" : {"type" : "string"}
              }
      },
      "additionalProperties" : false
    },
    "ProtectedDeliveryBinding" : {
      "type" : "object",
      "description" : "Immutable encrypted artifact/window metadata for protected delivery.",
      "properties" : {
        "ENCRYPTED_CID" : {
                "type" : "string"
              },
        "MANIFEST_CID" : {
                "type" : "string"
              },
        "CONTENT_HASH" : {
                "type" : "string"
              },
        "CONTENT_KEY_ID" : {
                "type" : "string"
              },
        "LICENSE_MODULE_ID" : {
                "type" : "string"
              },
        "MODULE_ID" : {
                "type" : "string"
              },
        "MODULE_VERSION" : {
                "type" : "string"
              },
        "REQUIRED_SCOPES" : {
                "type" : "array", "items" : {"type" : "string"}
              },
        "GRANT_SCOPE" : {
                "type" : "string"
              },
        "DELIVERY_PROTOCOL" : {
                "type" : "string"
              },
        "FIELD_STREAM_POLICY" : {
                "$ref" : "#/definitions/GrantFieldStreamPolicy"
              }
      },
      "additionalProperties" : false
    },
    "ProviderReputation" : {
      "type" : "object",
      "description" : "Provider reputation summary surfaced in marketplace listings.",
      "properties" : {
        "TOTAL_SALES" : {
                "type" : "integer", "minimum" : 0, "maximum" : 18446744073709551615
              },
        "AVERAGE_RATING_X10" : {
                "type" : "integer", "minimum" : 0, "maximum" : 65535
              },
        "TOTAL_RATINGS" : {
                "type" : "integer", "minimum" : 0, "maximum" : 4294967295
              },
        "UPTIME_PERCENTAGE_X100" : {
                "type" : "integer", "minimum" : 0, "maximum" : 65535
              },
        "AVG_DELIVERY_LATENCY_MS" : {
                "type" : "integer", "minimum" : 0, "maximum" : 4294967295
              },
        "DISPUTE_COUNT" : {
                "type" : "integer", "minimum" : 0, "maximum" : 4294967295
              },
        "PROVIDER_SINCE" : {
                "type" : "integer", "minimum" : 0, "maximum" : 18446744073709551615
              }
      },
      "additionalProperties" : false
    },
    "SpatialCoverage" : {
      "type" : "object",
      "description" : "Spatial coverage definition",
      "properties" : {
        "TYPE" : {
                "type" : "string",
                "description" : "Type of coverage: \"global\", \"region\", \"object_list\""
              },
        "REGIONS" : {
                "type" : "array", "items" : {"type" : "string"},
                "description" : "Regions covered, e.g., [\"LEO\", \"GEO\", \"MEO\"]"
              },
        "OBJECT_IDS" : {
                "type" : "array", "items" : {"type" : "string"},
                "description" : "Specific NORAD IDs or catalog numbers"
              },
        "MIN_ALTITUDE_KM" : {
                "type" : "number",
                "description" : "Minimum altitude in kilometers for altitude-bounded offerings"
              },
        "MAX_ALTITUDE_KM" : {
                "type" : "number",
                "description" : "Maximum altitude in kilometers for altitude-bounded offerings"
              },
        "GEO_BOUNDS" : {
                "type" : "array", "items" : {"type" : "number"},
                "description" : "Bounding box as [min_lat, min_lon, max_lat, max_lon]"
              }
      },
      "additionalProperties" : false
    },
    "TemporalCoverage" : {
      "type" : "object",
      "description" : "Temporal coverage definition",
      "properties" : {
        "START_EPOCH" : {
                "type" : "string",
                "description" : "Start epoch in ISO 8601 format"
              },
        "END_EPOCH" : {
                "type" : "string",
                "description" : "End epoch in ISO 8601 format"
              },
        "UPDATE_FREQUENCY" : {
                "type" : "string",
                "description" : "Update frequency: \"realtime\", \"hourly\", \"daily\""
              },
        "HISTORICAL_DEPTH" : {
                "type" : "integer", "minimum" : 0, "maximum" : 4294967295,
                "description" : "Days of historical data available"
              },
        "LATENCY_SECONDS" : {
                "type" : "integer", "minimum" : 0, "maximum" : 4294967295,
                "description" : "Typical provider latency in seconds"
              }
      },
      "additionalProperties" : false
    },
    "DataCoverage" : {
      "type" : "object",
      "description" : "Data coverage combining spatial and temporal",
      "properties" : {
        "SPATIAL" : {
                "$ref" : "#/definitions/SpatialCoverage",
                "description" : "Spatial coverage definition"
              },
        "TEMPORAL" : {
                "$ref" : "#/definitions/TemporalCoverage",
                "description" : "Temporal coverage definition"
              }
      },
      "additionalProperties" : false
    },
    "PricingTier" : {
      "type" : "object",
      "description" : "Pricing tier for a listing",
      "properties" : {
        "NAME" : {
                "type" : "string",
                "description" : "Tier name, e.g., \"Basic\", \"Pro\", \"Enterprise\""
              },
        "PRICE_AMOUNT" : {
                "type" : "integer", "minimum" : 0, "maximum" : 18446744073709551615,
                "description" : "Price in smallest unit (cents, satoshis, etc.)"
              },
        "PRICE_CURRENCY" : {
                "type" : "string",
                "description" : "Currency code: \"USD\", \"ETH\", \"SOL\", \"SDN_CREDITS\""
              },
        "DURATION_DAYS" : {
                "type" : "integer", "minimum" : 0, "maximum" : 4294967295,
                "description" : "Duration in days (0 = one-time purchase)"
              },
        "RATE_LIMIT" : {
                "type" : "integer", "minimum" : 0, "maximum" : 4294967295,
                "description" : "Rate limit in requests per hour"
              },
        "FEATURES" : {
                "type" : "array", "items" : {"type" : "string"},
                "description" : "List of features included in this tier"
              },
        "MAX_RECORDS_PER_REQUEST" : {
                "type" : "integer", "minimum" : 0, "maximum" : 4294967295,
                "description" : "Maximum records returned per request"
              },
        "DESCRIPTION" : {
                "type" : "string",
                "description" : "Human-readable tier description"
              }
      },
      "additionalProperties" : false
    },
    "STF" : {
      "type" : "object",
      "description" : "Storefront Listing - Data marketplace listing",
      "properties" : {
        "LISTING_ID" : {
                "type" : "string",
                "description" : "Unique identifier for the listing"
              },
        "PROVIDER_PEER_ID" : {
                "type" : "string",
                "description" : "Peer ID of the data provider"
              },
        "PROVIDER_EPM_CID" : {
                "type" : "string",
                "description" : "IPFS CID of provider's EPM (Entity Profile Message)"
              },
        "TITLE" : {
                "type" : "string",
                "description" : "Title of the data listing"
              },
        "DESCRIPTION" : {
                "type" : "string",
                "description" : "Detailed description of the data offering"
              },
        "DATA_TYPES" : {
                "type" : "array", "items" : {"type" : "string"},
                "description" : "SDS data types offered, e.g., [\"OMM\", \"CDM\", \"TLE\"]"
              },
        "COVERAGE" : {
                "$ref" : "#/definitions/DataCoverage",
                "description" : "Coverage information (spatial and temporal)"
              },
        "SAMPLE_CID" : {
                "type" : "string",
                "description" : "IPFS CID of sample data"
              },
        "ACCESS_TYPE" : {
                "$ref" : "#/definitions/accessCategory",
                "description" : "Type of access offered"
              },
        "ENCRYPTION_REQUIRED" : {
                "type" : "boolean",
                "description" : "Whether encryption is required for data delivery"
              },
        "PRICING" : {
                "type" : "array", "items" : {"$ref" : "#/definitions/PricingTier"},
                "description" : "Available pricing tiers"
              },
        "ACCEPTED_PAYMENTS" : {
                "type" : "array", "items" : {"$ref" : "#/definitions/paymentMethod"},
                "description" : "Payment methods accepted"
              },
        "CREATED_AT" : {
                "type" : "integer", "minimum" : 0, "maximum" : 18446744073709551615,
                "description" : "Unix timestamp when listing was created"
              },
        "UPDATED_AT" : {
                "type" : "integer", "minimum" : 0, "maximum" : 18446744073709551615,
                "description" : "Unix timestamp when listing was last updated"
              },
        "ACTIVE" : {
                "type" : "boolean",
                "description" : "Whether the listing is currently active"
              },
        "SIGNATURE" : {
                "type" : "array", "items" : {"type" : "integer", "minimum" : 0, "maximum" :255},
                "description" : "Ed25519 signature from provider"
              },
        "LISTING_KIND" : {
                "$ref" : "#/definitions/listingCategory",
                "description" : "Listing category: data stream or WASM module"
              },
        "TAGS" : {
                "type" : "array", "items" : {"type" : "string"},
                "description" : "Search tags"
              },
        "SAMPLE_RECORD_COUNT" : {
                "type" : "integer", "minimum" : 0, "maximum" : 4294967295,
                "description" : "Number of records in sample data, when available"
              },
        "DELIVERY_METHODS" : {
                "type" : "array", "items" : {"type" : "string"},
                "description" : "Supported delivery methods"
              },
        "PROTECTED_DELIVERY" : {
                "$ref" : "#/definitions/ProtectedDeliveryBinding",
                "description" : "Protected delivery metadata for encrypted artifacts or streams"
              },
        "REPUTATION" : {
                "$ref" : "#/definitions/ProviderReputation",
                "description" : "Provider reputation summary"
              },
        "VERSION" : {
                "type" : "integer", "minimum" : 0, "maximum" : 4294967295,
                "description" : "Listing version"
              },
        "EXPIRES_AT" : {
                "type" : "integer", "minimum" : 0, "maximum" : 18446744073709551615,
                "description" : "Unix timestamp when the listing expires, or 0 for no expiry"
              },
        "TERMS_CID" : {
                "type" : "string",
                "description" : "Terms document CID"
              },
        "LICENSE" : {
                "type" : "string",
                "description" : "License label or SPDX-style identifier"
              },
        "SOURCE_PEER_ID" : {
                "type" : "string",
                "description" : "Peer ID this listing was sourced from when discovered remotely"
              }
      },
      "required" : ["LISTING_ID", "PROVIDER_PEER_ID", "TITLE"],
      "additionalProperties" : false
    }
  },
  "$ref" : "#/definitions/STF"
}
