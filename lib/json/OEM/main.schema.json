    "PPEPositionRecord" : {
      "type" : "object",
      "description" : "A single time-segment record of polynomial coefficients for Cartesian position\n(and optionally velocity). Coefficients are stored per axis.\n\nTo evaluate position at time t within this record's validity window:\n1. Compute normalized time: tau = (t - EPOCH_MID) / EPOCH_HALF_SPAN\nwhere tau is in [-1, +1].\n2. Evaluate the polynomial basis of degree (NUM_COEFFICIENTS - 1) using\nthe coefficients for each axis.\n\nVelocity coefficients, if present, follow the same evaluation procedure.\nIf HAS_VELOCITY_COEFFICIENTS is false, velocity can be obtained by\nanalytically differentiating the position polynomial.",
      "properties" : {
        "EPOCH_MID" : {
                "type" : "string",
                "description" : "Midpoint epoch of this record's validity window (ISO 8601 UTC or TDB).\nTogether with EPOCH_HALF_SPAN, defines the time interval:\n[EPOCH_MID - EPOCH_HALF_SPAN, EPOCH_MID + EPOCH_HALF_SPAN]"
              },
        "EPOCH_HALF_SPAN" : {
                "type" : "number",
                "description" : "Half-span of the validity window in seconds.\nThe full span is 2 * EPOCH_HALF_SPAN seconds centered on EPOCH_MID."
              },
        "NUM_COEFFICIENTS" : {
                "type" : "integer", "minimum" : 0, "maximum" : 65535,
                "description" : "Number of polynomial coefficients per axis.\nThe polynomial degree is (NUM_COEFFICIENTS - 1).\nTypical values: 8-32 for high-fidelity ephemeris fits."
              },
        "BASIS_TYPE" : {
                "$ref" : "#/definitions/polynomialBasisType",
                "description" : "Polynomial basis type for interpreting the coefficient arrays."
              },
        "POS_COEFF_X" : {
                "type" : "array", "items" : {"type" : "number"},
                "description" : "Position coefficients for X-axis (km).\nLength must equal NUM_COEFFICIENTS. Ordered c0, c1, ..., c_{N-1}."
              },
        "POS_COEFF_Y" : {
                "type" : "array", "items" : {"type" : "number"},
                "description" : "Position coefficients for Y-axis (km).\nLength must equal NUM_COEFFICIENTS."
              },
        "POS_COEFF_Z" : {
                "type" : "array", "items" : {"type" : "number"},
                "description" : "Position coefficients for Z-axis (km).\nLength must equal NUM_COEFFICIENTS."
              },
        "HAS_VELOCITY_COEFFICIENTS" : {
                "type" : "boolean",
                "description" : "Whether explicit velocity coefficients are provided.\nIf false, velocity should be derived by differentiating the position polynomial."
              },
        "VEL_COEFF_X" : {
                "type" : "array", "items" : {"type" : "number"},
                "description" : "Velocity coefficients for X-axis (km/s). Optional.\nLength must equal NUM_COEFFICIENTS if present."
              },
        "VEL_COEFF_Y" : {
                "type" : "array", "items" : {"type" : "number"},
                "description" : "Velocity coefficients for Y-axis (km/s). Optional."
              },
        "VEL_COEFF_Z" : {
                "type" : "array", "items" : {"type" : "number"},
                "description" : "Velocity coefficients for Z-axis (km/s). Optional."
              },
        "MAX_POSITION_RESIDUAL" : {
                "type" : "number",
                "description" : "Maximum position fit residual over this segment (km). Optional quality metric."
              },
        "RMS_POSITION_RESIDUAL" : {
                "type" : "number",
                "description" : "RMS position fit residual over this segment (km). Optional quality metric."
              }
      },
      "required" : ["EPOCH_MID", "POS_COEFF_X", "POS_COEFF_Y", "POS_COEFF_Z"],
      "additionalProperties" : false
    },
    "PPEOrbitalElementRecord" : {
      "type" : "object",
      "description" : "A single time-segment record of polynomial coefficients for classical orbital elements.\n\nThe six classical elements are:\n1. SMA or R_PERIAPSIS (size/shape) — see SIZE_SHAPE_TYPE\n2. Eccentricity (dimensionless)\n3. Inclination (degrees)\n4. Right Ascension of Ascending Node / RAAN (degrees)\n5. Argument of Periapsis (degrees)\n6. Anomaly (degrees) — see ANOMALY_TYPE\n\nEvaluation follows the same normalized-time procedure as PPEPositionRecord.",
      "properties" : {
        "EPOCH_MID" : {
                "type" : "string",
                "description" : "Midpoint epoch of this record's validity window (ISO 8601 UTC or TDB)."
              },
        "EPOCH_HALF_SPAN" : {
                "type" : "number",
                "description" : "Half-span of the validity window in seconds."
              },
        "NUM_COEFFICIENTS" : {
                "type" : "integer", "minimum" : 0, "maximum" : 65535,
                "description" : "Number of polynomial coefficients per element."
              },
        "BASIS_TYPE" : {
                "$ref" : "#/definitions/polynomialBasisType",
                "description" : "Polynomial basis type for interpreting the coefficient arrays."
              },
        "SIZE_SHAPE_TYPE" : {
                "$ref" : "#/definitions/sizeShapeType",
                "description" : "Parameterization of the first orbital element (SMA vs R_PERIAPSIS)."
              },
        "ANOMALY_TYPE" : {
                "$ref" : "#/definitions/ppeAnomalyType",
                "description" : "Anomaly type for the sixth orbital element."
              },
        "COEFF_SIZE_SHAPE" : {
                "type" : "array", "items" : {"type" : "number"},
                "description" : "Coefficients for SMA or radius of periapsis (km).\nLength must equal NUM_COEFFICIENTS."
              },
        "COEFF_ECCENTRICITY" : {
                "type" : "array", "items" : {"type" : "number"},
                "description" : "Coefficients for eccentricity (dimensionless).\nLength must equal NUM_COEFFICIENTS."
              },
        "COEFF_INCLINATION" : {
                "type" : "array", "items" : {"type" : "number"},
                "description" : "Coefficients for inclination (degrees).\nLength must equal NUM_COEFFICIENTS."
              },
        "COEFF_RAAN" : {
                "type" : "array", "items" : {"type" : "number"},
                "description" : "Coefficients for RAAN (degrees).\nLength must equal NUM_COEFFICIENTS."
              },
