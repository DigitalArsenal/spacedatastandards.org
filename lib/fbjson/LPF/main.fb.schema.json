{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "definitions": {
    "licensingProofMessageType": {
      "type": "string",
      "enum": [
        "ProofRequest",
        "ProofAccepted",
        "ProofRejected"
      ],
      "x-flatbuffer-type": "enum",
      "x-flatbuffer-enum-type": "byte",
      "x-flatbuffer-enum-values": {
        "ProofRequest": {
          "value": 0
        },
        "ProofAccepted": {
          "value": 1
        },
        "ProofRejected": {
          "value": 2
        }
      }
    },
    "LPF": {
      "type": "object",
      "description": "Licensing proof message",
      "properties": {
        "MESSAGE_TYPE": {
          "$ref": "#/definitions/licensingProofMessageType",
          "description": "Message type",
          "x-flatbuffer-type": "enum",
          "x-flatbuffer-enum-type": "byte",
          "x-flatbuffer-enum-values": {
            "ProofRequest": {
              "value": 0
            },
            "ProofAccepted": {
              "value": 1
            },
            "ProofRejected": {
              "value": 2
            }
          }
        },
        "REQUEST_ID": {
          "type": "string",
          "description": "Unique request identifier",
          "x-flatbuffer-type": "string",
          "x-flatbuffer-required": true
        },
        "MODULE_ID": {
          "type": "string",
          "description": "Canonical module identifier",
          "x-flatbuffer-type": "string",
          "x-flatbuffer-required": true
        },
        "MODULE_VERSION": {
          "type": "string",
          "description": "Optional requested module version",
          "x-flatbuffer-type": "string"
        },
        "REQUESTER_PEER_ID": {
          "type": "string",
          "description": "Requester peer identifier",
          "x-flatbuffer-type": "string"
        },
        "REQUESTER_XPUB": {
          "type": "string",
          "description": "Requester account identity or wallet xpub",
          "x-flatbuffer-type": "string"
        },
        "REQUESTED_DOMAIN": {
          "type": "string",
          "description": "Requested domain proved for policy evaluation",
          "x-flatbuffer-type": "string"
        },
        "REQUESTED_TIMEOUT_MS": {
          "type": "integer",
          "minimum": 0,
          "maximum": 18446744073709551615,
          "description": "Requested timeout in milliseconds",
          "x-flatbuffer-type": "uint64"
        },
        "REQUESTER_EPHEMERAL_PUBKEY": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0,
            "maximum": 255
          },
          "description": "Requester ephemeral X25519 public key",
          "x-flatbuffer-type": "[ubyte]"
        },
        "CHALLENGE_NONCE": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0,
            "maximum": 255
          },
          "description": "Provider-issued challenge nonce being proved",
          "x-flatbuffer-type": "[ubyte]"
        },
        "CHALLENGE_EXPIRES_AT": {
          "type": "integer",
          "minimum": 0,
          "maximum": 18446744073709551615,
          "description": "Challenge expiration time being acknowledged",
          "x-flatbuffer-type": "uint64"
        },
        "PROVIDER_PEER_ID": {
          "type": "string",
          "description": "Provider peer identifier that issued the challenge",
          "x-flatbuffer-type": "string"
        },
        "SIGNATURE": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0,
            "maximum": 255
          },
          "description": "Detached requester signature over the challenge payload",
          "x-flatbuffer-type": "[ubyte]"
        },
        "SIGNING_PUBKEY": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0,
            "maximum": 255
          },
          "description": "Requester signing public key",
          "x-flatbuffer-type": "[ubyte]"
        },
        "TIMESTAMP_MS": {
          "type": "integer",
          "minimum": 0,
          "maximum": 18446744073709551615,
          "description": "Proof timestamp in milliseconds since epoch",
          "x-flatbuffer-type": "uint64"
        },
        "REJECTION_CODE": {
          "type": "string",
          "description": "Structured rejection code",
          "x-flatbuffer-type": "string"
        },
        "REJECTION_MESSAGE": {
          "type": "string",
          "description": "Structured rejection message",
          "x-flatbuffer-type": "string"
        }
      },
      "required": [
        "REQUEST_ID",
        "MODULE_ID"
      ],
      "additionalProperties": false
    }
  },
  "$ref": "#/definitions/LPF",
  "x-flatbuffer-root-type": "LPF",
  "x-flatbuffer-file-identifier": "$LPF"
}