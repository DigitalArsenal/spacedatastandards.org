    "PLGAcceptedTypeSet": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "SET_ID": {
          "type": "string",
          "description": "Stable type-set identifier within the port.",
          "x-flatbuffer-type": "string",
          "x-flatbuffer-required": true
        },
        "ALLOWED_TYPES": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/FlatBufferTypeRef"
          },
          "description": "Specific FlatBuffer types accepted by the set.",
          "x-flatbuffer-type": "[FlatBufferTypeRef]"
        },
        "ALLOWED_WIRE_FORMATS": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/payloadWireFormat"
          },
          "description": "FLATBUFFER MUST also be present for the same schemas.",
          "x-flatbuffer-type": "[payloadWireFormat]"
        },
        "DESCRIPTION": {
          "type": "string",
          "description": "Human-readable explanation of the accepted schema family.",
          "x-flatbuffer-type": "string"
        }
      },
      "description": "Accepted schema family for a port. When a port accepts multiple wire formats (canonical FlatBuffer + aligned-binary), each ALLOWED_TYPE entry carries its own TAB.FlatBufferTypeRef with the schema identity, and the enclosing PLGPortManifest advertises both wire formats via ALLOWED_WIRE_FORMATS. Per SDK contract: a port that advertises aligned-binary MUST also advertise the canonical flatbuffer fallback for the same schema and file identifier in the same set.",
      "required": [
        "SET_ID"
      ]
    },
    "PLGPortManifest": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "PORT_ID": {
          "type": "string",
          "description": "Stable port identifier within the method.",
          "x-flatbuffer-type": "string",
          "x-flatbuffer-required": true
        },
        "DISPLAY_NAME": {
          "type": "string",
          "description": "Human-readable name for UIs.",
          "x-flatbuffer-type": "string"
