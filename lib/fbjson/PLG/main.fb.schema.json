        "Unlisted": {
          "value": 1,
          "description": "Addressable directly but hidden from public browse surfaces"
        },
        "Retired": {
          "value": 2,
          "description": "No longer offered for new installs or purchases"
        }
      }
    },
    "invokeSurfaceKind": {
      "type": "integer",
      "x-flatbuffer-type": "enum",
      "x-flatbuffer-enum-type": "ubyte",
      "description": "artifact can support multiple.",
      "enum": [
        0,
        1
      ],
      "x-flatbuffer-enum-values": {
        "DIRECT": {
          "value": 0,
          "description": "Direct ABI \u2014 host calls `plugin_invoke_stream` in-process."
        },
        "COMMAND": {
          "value": 1,
          "description": "Command surface \u2014 envelope is queued by a runtime host."
        }
      }
    },
    "drainBehavior": {
      "type": "integer",
      "x-flatbuffer-type": "enum",
      "x-flatbuffer-enum-type": "ubyte",
      "description": "(`DRAIN_POLICY` would collide otherwise).",
      "enum": [
        0,
        1,
        2
      ],
      "x-flatbuffer-enum-values": {
        "SINGLE_SHOT": {
          "value": 0,
          "description": "One invocation consumes exactly one input frame."
        },
        "DRAIN_UNTIL_YIELD": {
          "value": 1,
          "description": "Invocation drains queued work until it voluntarily yields."
        },
        "DRAIN_TO_EMPTY": {
          "value": 2,
          "description": "Invocation drains to empty before returning."
        }
      }
    },
