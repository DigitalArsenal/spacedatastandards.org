        "ACCEPTED_TYPE_SETS": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/PLGAcceptedTypeSet"
          },
          "description": "Type sets accepted on this port.",
          "x-flatbuffer-type": "[PLGAcceptedTypeSet]"
        },
        "MIN_STREAMS": {
          "type": "integer",
          "description": "Minimum number of streams that must be connected.",
          "x-flatbuffer-type": "uint16",
          "x-flatbuffer-default": "1"
        },
        "MAX_STREAMS": {
          "type": "integer",
          "description": "Maximum number of streams that may be connected.",
          "x-flatbuffer-type": "uint16",
          "x-flatbuffer-default": "1"
        },
        "REQUIRED": {
          "type": "boolean",
          "description": "Whether the port must be connected for invocation.",
          "x-flatbuffer-type": "bool",
          "x-flatbuffer-default": "true"
        },
        "DESCRIPTION": {
          "type": "string",
          "description": "Optional human-readable description.",
          "x-flatbuffer-type": "string"
        }
      },
      "description": "One input or output port on a method.",
      "required": [
        "PORT_ID"
      ]
    },
