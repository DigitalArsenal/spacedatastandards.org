    "PluginCapability": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "NAME": {
          "type": "string",
          "description": "Capability name, e.g., \"gpu_compute\", \"wasm_simd\"",
          "x-flatbuffer-type": "string"
