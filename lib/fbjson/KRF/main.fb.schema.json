    "keyReferenceAlgorithm": {
      "type": "string",
      "enum": [
        "Unknown",
        "Ed25519Seed",
        "Ed25519Public",
        "X25519Private",
        "X25519Public",
        "Aes256Gcm",
        "Opaque"
      ],
      "x-flatbuffer-type": "enum",
      "x-flatbuffer-enum-type": "byte",
      "x-flatbuffer-enum-values": {
        "Unknown": {
