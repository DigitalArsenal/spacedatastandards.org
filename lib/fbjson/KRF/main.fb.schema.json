          "value": 4
        },
        "Aes256Gcm": {
          "value": 5
        },
        "Opaque": {
          "value": 6
        }
      }
    },
    "KRF": {
      "type": "object",
      "description": "Key Reference Frame",
      "properties": {
        "KEY_ID": {
          "type": "string",
          "description": "Logical key identifier used across publication and grant records.",
          "x-flatbuffer-type": "string"
        },
        "SLOT_ID": {
          "type": "string",
          "description": "Host-managed key slot or key handle identifier.",
          "x-flatbuffer-type": "string"
        },
        "ROLE": {
          "$ref": "#/definitions/keyReferenceRole",
          "description": "Role the referenced key fulfills for the module flow.",
          "x-flatbuffer-type": "enum",
          "x-flatbuffer-enum-type": "byte",
          "x-flatbuffer-enum-values": {
            "Unknown": {
              "value": 0
            },
            "ProviderSigning": {
              "value": 1
            },
            "ProviderWrapping": {
              "value": 2
            },
            "RequesterSigning": {
              "value": 3
            },
            "PublicationContent": {
              "value": 4
            },
            "VerificationKey": {
              "value": 5
            },
            "DecryptKey": {
              "value": 6
            }
          }
        },
        "ALGORITHM": {
          "$ref": "#/definitions/keyReferenceAlgorithm",
          "description": "Algorithm or key family for the referenced key.",
          "x-flatbuffer-type": "enum",
          "x-flatbuffer-enum-type": "byte",
          "x-flatbuffer-enum-values": {
            "Unknown": {
              "value": 0
            },
            "Ed25519Seed": {
              "value": 1
            },
            "Ed25519Public": {
              "value": 2
            },
            "X25519Private": {
              "value": 3
            },
            "X25519Public": {
              "value": 4
            },
            "Aes256Gcm": {
              "value": 5
            },
            "Opaque": {
              "value": 6
            }
          }
        },
        "PUBLIC_KEY": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0,
            "maximum": 255
          },
          "description": "Optional public bytes for verification or peer identity binding.",
          "x-flatbuffer-type": "[ubyte]"
        },
        "VERSION": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4294967295,
          "description": "Logical version of the referenced key.",
          "x-flatbuffer-type": "uint32"
        },
        "EXPIRES_AT": {
          "type": "integer",
          "minimum": 0,
          "maximum": 18446744073709551615,
          "description": "Expiration time in unix milliseconds, or 0 if unbounded.",
          "x-flatbuffer-type": "uint64"
        },
        "HOST_MANAGED": {
          "type": "boolean",
          "description": "True when the secret material remains in the host key slot.",
          "x-flatbuffer-type": "bool"
        }
      },
      "additionalProperties": false
    }
