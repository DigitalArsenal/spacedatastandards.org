{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "definitions": {
    "lambertTransferPath": {
      "type": "string",
      "enum": [
        "SHORT",
        "LONG"
      ],
      "x-flatbuffer-type": "enum",
      "x-flatbuffer-enum-type": "byte",
      "x-flatbuffer-enum-values": {
        "SHORT": {
          "value": 0
        },
        "LONG": {
          "value": 1
        }
      }
    },
    "LMS": {
      "type": "object",
      "description": "Lambert boundary-value solve request.",
      "properties": {
        "REQUEST_ID": {
          "type": "string",
          "description": "Caller-supplied request identifier for result correlation.",
          "x-flatbuffer-type": "string"
        },
        "R1_X": {
          "type": "number",
          "description": "Initial position X component (km).",
          "x-flatbuffer-type": "double"
        },
        "R1_Y": {
          "type": "number",
          "description": "Initial position Y component (km).",
          "x-flatbuffer-type": "double"
        },
        "R1_Z": {
          "type": "number",
          "description": "Initial position Z component (km).",
          "x-flatbuffer-type": "double"
        },
        "R2_X": {
          "type": "number",
          "description": "Final position X component (km).",
          "x-flatbuffer-type": "double"
        },
        "R2_Y": {
          "type": "number",
          "description": "Final position Y component (km).",
          "x-flatbuffer-type": "double"
        },
        "R2_Z": {
          "type": "number",
          "description": "Final position Z component (km).",
          "x-flatbuffer-type": "double"
        },
        "TOF_SEC": {
          "type": "number",
          "description": "Time of flight (seconds). Must be greater than zero.",
          "x-flatbuffer-type": "double"
        },
        "MU_KM3_S2": {
          "type": "number",
          "description": "Central-body gravitational parameter (km^3/s^2). Must be greater than zero.",
          "x-flatbuffer-type": "double"
        },
        "TRANSFER_WAY": {
          "$ref": "#/definitions/lambertTransferPath",
          "description": "Short-way or long-way transfer selection.",
          "x-flatbuffer-type": "enum",
          "x-flatbuffer-enum-type": "byte",
          "x-flatbuffer-enum-values": {
            "SHORT": {
              "value": 0
            },
            "LONG": {
              "value": 1
            }
          }
        },
        "MAX_REVS": {
          "type": "integer",
          "minimum": 0,
          "maximum": 65535,
          "description": "Maximum complete revolutions to search. Zero means single-revolution only.",
          "x-flatbuffer-type": "uint16"
        },
        "REF_FRAME": {
          "type": "string",
          "description": "Inertial reference frame label for both position vectors (for example GCRF, EME2000, ICRF).",
          "x-flatbuffer-type": "string"
        },
        "EPOCH": {
          "type": "string",
          "description": "Optional epoch/time-scale label for provenance. The solver uses TOF, not epoch, internally.",
          "x-flatbuffer-type": "string"
        },
        "FLAGS": {
          "type": "integer",
          "minimum": 0,
          "maximum": 65535,
          "description": "Request flags reserved for future compatibility.",
          "x-flatbuffer-type": "uint16"
        }
      },
      "additionalProperties": false
    }
  },
  "$ref": "#/definitions/LMS",
  "x-flatbuffer-root-type": "LMS",
  "x-flatbuffer-file-identifier": "$LMS"
}