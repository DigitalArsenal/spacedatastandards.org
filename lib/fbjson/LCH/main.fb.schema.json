{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "definitions": {
    "licensingChallengeRole": {
      "type": "string",
      "enum": [
        "Requester",
        "Provider"
      ],
      "x-flatbuffer-type": "enum",
      "x-flatbuffer-enum-type": "byte",
      "x-flatbuffer-enum-values": {
        "Requester": {
          "value": 0
        },
        "Provider": {
          "value": 1
        }
      }
    },
    "licensingChallengeMessageType": {
      "type": "string",
      "enum": [
        "Request",
        "Response",
        "Error"
      ],
      "x-flatbuffer-type": "enum",
      "x-flatbuffer-enum-type": "byte",
      "x-flatbuffer-enum-values": {
        "Request": {
          "value": 0
        },
        "Response": {
          "value": 1
        },
        "Error": {
          "value": 2
        }
      }
    },
    "LCH": {
      "type": "object",
      "description": "Licensing challenge message",
      "properties": {
        "MESSAGE_TYPE": {
          "$ref": "#/definitions/licensingChallengeMessageType",
          "description": "Message type",
          "x-flatbuffer-type": "enum",
          "x-flatbuffer-enum-type": "byte",
          "x-flatbuffer-enum-values": {
            "Request": {
              "value": 0
            },
            "Response": {
              "value": 1
            },
            "Error": {
              "value": 2
            }
          }
        },
        "ROLE": {
          "$ref": "#/definitions/licensingChallengeRole",
          "description": "Sender role",
          "x-flatbuffer-type": "enum",
          "x-flatbuffer-enum-type": "byte",
          "x-flatbuffer-enum-values": {
            "Requester": {
              "value": 0
            },
            "Provider": {
              "value": 1
            }
          }
        },
        "REQUEST_ID": {
          "type": "string",
          "description": "Unique request identifier",
          "x-flatbuffer-type": "string",
          "x-flatbuffer-required": true
        },
        "MODULE_ID": {
          "type": "string",
          "description": "Canonical module identifier",
          "x-flatbuffer-type": "string",
          "x-flatbuffer-required": true
        },
        "MODULE_VERSION": {
          "type": "string",
          "description": "Optional requested module version",
          "x-flatbuffer-type": "string"
        },
        "REQUESTER_PEER_ID": {
          "type": "string",
          "description": "Requester peer identifier",
          "x-flatbuffer-type": "string"
        },
        "REQUESTER_XPUB": {
          "type": "string",
          "description": "Requester account identity or wallet xpub",
          "x-flatbuffer-type": "string"
        },
        "REQUESTER_SIGNING_PUBKEY": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0,
            "maximum": 255
          },
          "description": "Requester Ed25519 signing public key",
          "x-flatbuffer-type": "[ubyte]"
        },
        "REQUESTER_EPHEMERAL_PUBKEY": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0,
            "maximum": 255
          },
          "description": "Requester ephemeral X25519 public key",
          "x-flatbuffer-type": "[ubyte]"
        },
        "REQUESTED_DOMAIN": {
          "type": "string",
          "description": "Requested domain for policy evaluation",
          "x-flatbuffer-type": "string"
        },
        "REQUESTED_TIMEOUT_MS": {
          "type": "integer",
          "minimum": 0,
          "maximum": 18446744073709551615,
          "description": "Requested timeout in milliseconds",
          "x-flatbuffer-type": "uint64"
        },
        "REQUESTED_AT": {
          "type": "integer",
          "minimum": 0,
          "maximum": 18446744073709551615,
          "description": "Request timestamp in milliseconds since epoch",
          "x-flatbuffer-type": "uint64"
        },
        "CHALLENGE_NONCE": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0,
            "maximum": 255
          },
          "description": "Provider-issued challenge nonce",
          "x-flatbuffer-type": "[ubyte]"
        },
        "EXPIRES_AT": {
          "type": "integer",
          "minimum": 0,
          "maximum": 18446744073709551615,
          "description": "Challenge expiration time in milliseconds since epoch",
          "x-flatbuffer-type": "uint64"
        },
        "PROVIDER_PEER_ID": {
          "type": "string",
          "description": "Provider peer identifier",
          "x-flatbuffer-type": "string"
        },
        "ERROR_CODE": {
          "type": "string",
          "description": "Structured error code",
          "x-flatbuffer-type": "string"
        },
        "ERROR_MESSAGE": {
          "type": "string",
          "description": "Structured error message",
          "x-flatbuffer-type": "string"
        }
      },
      "required": [
        "REQUEST_ID",
        "MODULE_ID"
      ],
      "additionalProperties": false
    }
  },
  "$ref": "#/definitions/LCH",
  "x-flatbuffer-root-type": "LCH",
  "x-flatbuffer-file-identifier": "$LCH"
}