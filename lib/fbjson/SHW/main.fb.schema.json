{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "definitions": {
    "glslStage": {
      "type": "string",
      "enum": [
        "VERTEX",
        "FRAGMENT",
        "COMPUTE",
        "GEOMETRY",
        "TESS_CONTROL",
        "TESS_EVALUATION"
      ],
      "x-flatbuffer-type": "enum",
      "x-flatbuffer-enum-type": "ubyte",
      "x-flatbuffer-enum-values": {
        "VERTEX": {
          "value": 0
        },
        "FRAGMENT": {
          "value": 1
        },
        "COMPUTE": {
          "value": 2
        },
        "GEOMETRY": {
          "value": 3
        },
        "TESS_CONTROL": {
          "value": 4
        },
        "TESS_EVALUATION": {
          "value": 5
        }
      }
    },
    "shaderHookPoint": {
      "type": "string",
      "enum": [
        "NONE",
        "VERTEX_PRE_TRANSFORM",
        "VERTEX_POST_TRANSFORM",
        "FRAGMENT_PRE_SHADE",
        "FRAGMENT_POST_SHADE",
        "FRAGMENT_FINAL_COLOR",
        "POSTPROCESS"
      ],
      "x-flatbuffer-type": "enum",
      "x-flatbuffer-enum-type": "ubyte",
      "x-flatbuffer-enum-values": {
        "NONE": {
          "value": 0
        },
        "VERTEX_PRE_TRANSFORM": {
          "value": 1
        },
        "VERTEX_POST_TRANSFORM": {
          "value": 2
        },
        "FRAGMENT_PRE_SHADE": {
          "value": 3
        },
        "FRAGMENT_POST_SHADE": {
          "value": 4
        },
        "FRAGMENT_FINAL_COLOR": {
          "value": 5
        },
        "POSTPROCESS": {
          "value": 6
        }
      }
    },
    "shaderUniformType": {
      "type": "string",
      "enum": [
        "FLOAT",
        "VEC2",
        "VEC3",
        "VEC4",
        "INT",
        "IVEC2",
        "IVEC3",
        "IVEC4",
        "UINT",
        "UVEC2",
        "UVEC3",
        "UVEC4",
        "BOOL",
        "BVEC2",
        "BVEC3",
        "BVEC4",
        "MAT2",
        "MAT3",
        "MAT4",
        "SAMPLER_2D",
        "SAMPLER_CUBE",
        "SAMPLER_2D_ARRAY"
      ],
      "x-flatbuffer-type": "enum",
      "x-flatbuffer-enum-type": "ubyte",
      "x-flatbuffer-enum-values": {
        "FLOAT": {
