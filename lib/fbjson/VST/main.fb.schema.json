{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "definitions": {
    "viewerMapMode": {
      "type": "string",
      "enum": [
        "UNKNOWN",
        "GEOGRAPHICAL_DAY_NIGHT",
        "GEOGRAPHICAL_CONSTANT",
        "POLITICAL"
      ],
      "x-flatbuffer-type": "enum",
      "x-flatbuffer-enum-type": "byte",
      "x-flatbuffer-enum-values": {
        "UNKNOWN": {
          "value": 0
        },
        "GEOGRAPHICAL_DAY_NIGHT": {
          "value": 1
        },
        "GEOGRAPHICAL_CONSTANT": {
          "value": 2
        },
        "POLITICAL": {
          "value": 3
        }
      }
    },
    "viewerCameraFrameMode": {
      "type": "string",
      "enum": [
        "DEFAULT",
        "RADIAL_INTRACK",
        "CROSSTRACK_INTRACK",
        "RADIAL_CROSSTRACK"
      ],
      "x-flatbuffer-type": "enum",
      "x-flatbuffer-enum-type": "byte",
      "x-flatbuffer-enum-values": {
        "DEFAULT": {
          "value": 0
        },
        "RADIAL_INTRACK": {
          "value": 1
        },
        "CROSSTRACK_INTRACK": {
          "value": 2
        },
        "RADIAL_CROSSTRACK": {
          "value": 3
        }
      }
    },
    "viewerSatelliteAlignmentMode": {
      "type": "string",
      "enum": [
        "UNKNOWN",
        "ORBITAL",
        "NADIR"
      ],
      "x-flatbuffer-type": "enum",
      "x-flatbuffer-enum-type": "byte",
      "x-flatbuffer-enum-values": {
        "UNKNOWN": {
          "value": 0
        },
        "ORBITAL": {
          "value": 1
        },
        "NADIR": {
          "value": 2
        }
      }
    },
    "VSTCameraRotation": {
      "type": "object",
      "description": "Camera rotation offset. Quaternions are preferred when present; Euler\nangles are retained for import of older scenario JSON.",
      "properties": {
        "YAW": {
          "type": "number",
          "description": "Yaw angle in degrees for Euler-angle camera imports.",
          "x-flatbuffer-type": "double"
        },
        "PITCH": {
          "type": "number",
          "description": "Pitch angle in degrees for Euler-angle camera imports.",
          "x-flatbuffer-type": "double"
        },
        "ROLL": {
          "type": "number",
          "description": "Roll angle in degrees for Euler-angle camera imports.",
          "x-flatbuffer-type": "double"
        },
        "QUATERNION_X": {
          "type": "number",
          "description": "Quaternion x component for camera orientation.",
          "x-flatbuffer-type": "double"
        },
        "QUATERNION_Y": {
          "type": "number",
          "description": "Quaternion y component for camera orientation.",
          "x-flatbuffer-type": "double"
        },
        "QUATERNION_Z": {
          "type": "number",
          "description": "Quaternion z component for camera orientation.",
          "x-flatbuffer-type": "double"
        },
        "QUATERNION_W": {
          "type": "number",
          "description": "Quaternion w component for camera orientation.",
          "x-flatbuffer-type": "double"
        },
        "USES_QUATERNION": {
          "type": "boolean",
          "description": "True when quaternion fields define the authoritative rotation.",
          "x-flatbuffer-type": "bool",
          "x-flatbuffer-default": "true"
        }
      },
      "additionalProperties": false
    },
    "VSTDisplaySettings": {
      "type": "object",
      "description": "App display toggles for a scenario viewer.",
      "properties": {
        "MAP_MODE": {
          "$ref": "#/definitions/viewerMapMode",
          "description": "Active map rendering mode for the scenario viewer.",
          "x-flatbuffer-type": "enum",
          "x-flatbuffer-enum-type": "byte",
          "x-flatbuffer-enum-values": {
            "UNKNOWN": {
              "value": 0
            },
            "GEOGRAPHICAL_DAY_NIGHT": {
              "value": 1
            },
            "GEOGRAPHICAL_CONSTANT": {
              "value": 2
            },
            "POLITICAL": {
              "value": 3
            }
          }
        },
        "SHOW_GEO_BELT_MARKERS": {
          "type": "boolean",
          "description": "Show geosynchronous belt reference markers.",
          "x-flatbuffer-type": "bool"
        },
        "SHOW_CIS_LUNAR": {
          "type": "boolean",
          "description": "Show cislunar reference content.",
          "x-flatbuffer-type": "bool"
        },
        "SHOW_EQUATOR": {
          "type": "boolean",
          "description": "Show the equator overlay.",
          "x-flatbuffer-type": "bool"
        },
        "SHOW_LATITUDE": {
          "type": "boolean",
          "description": "Show latitude grid lines.",
          "x-flatbuffer-type": "bool"
        },
        "SHOW_LONGITUDE": {
          "type": "boolean",
          "description": "Show longitude grid lines.",
          "x-flatbuffer-type": "bool"
        },
        "SHOW_SHADOW_CONES": {
          "type": "boolean",
          "description": "Show body shadow-cone overlays.",
          "x-flatbuffer-type": "bool"
        },
        "SHOW_GIF_CONTROLS": {
          "type": "boolean",
          "description": "Show animated capture or GIF export controls.",
          "x-flatbuffer-type": "bool"
        },
        "SHOW_ATMOSPHERE": {
          "type": "boolean",
          "description": "Render the atmospheric shell around the central body.",
          "x-flatbuffer-type": "bool"
        },
        "SHOW_SUN_DIRECTION_INDICATOR": {
          "type": "boolean",
          "description": "Show the sun-direction indicator overlay.",
          "x-flatbuffer-type": "bool"
        },
        "USE_STARFIELD": {
          "type": "boolean",
          "description": "Render the starfield background.",
          "x-flatbuffer-type": "bool"
        },
        "USE_STITCHED_ORBIT": {
          "type": "boolean",
          "description": "Render orbits as stitched continuous paths.",
          "x-flatbuffer-type": "bool"
        }
      },
      "additionalProperties": false
    },
    "VSTCameraOptions": {
      "type": "object",
      "description": "Camera options for a space-domain scenario viewer.",
      "properties": {
        "CAMERA_FRAME_MODE": {
          "$ref": "#/definitions/viewerCameraFrameMode",
          "description": "Camera frame relative to the focused target or default scene.",
          "x-flatbuffer-type": "enum",
          "x-flatbuffer-enum-type": "byte",
          "x-flatbuffer-enum-values": {
            "DEFAULT": {
              "value": 0
            },
            "RADIAL_INTRACK": {
              "value": 1
            },
            "CROSSTRACK_INTRACK": {
              "value": 2
            },
            "RADIAL_CROSSTRACK": {
              "value": 3
            }
          }
        },
        "SATELLITE_ALIGNMENT": {
          "$ref": "#/definitions/viewerSatelliteAlignmentMode",
          "description": "Satellite body alignment mode when focused on a satellite.",
          "x-flatbuffer-type": "enum",
          "x-flatbuffer-enum-type": "byte",
          "x-flatbuffer-enum-values": {
            "UNKNOWN": {
              "value": 0
            },
            "ORBITAL": {
              "value": 1
            },
            "NADIR": {
              "value": 2
            }
          }
        },
        "DISTANCE_FROM_TARGET": {
          "type": "number",
          "description": "Camera distance from the current target in kilometers.",
          "x-flatbuffer-type": "double"
        },
        "ROTATION": {
          "$ref": "#/definitions/VSTCameraRotation",
          "description": "Camera orientation offset.",
          "x-flatbuffer-type": "VSTCameraRotation"
        }
      },
      "additionalProperties": false
    },
    "VST": {
      "type": "object",
      "description": "Viewer State - display and camera state associated with a scenario.",
      "properties": {
        "CAMERA": {
          "$ref": "#/definitions/VSTCameraOptions",
          "description": "Camera settings for the current viewer state.",
          "x-flatbuffer-type": "VSTCameraOptions"
        },
        "DISPLAY_SETTINGS": {
          "$ref": "#/definitions/VSTDisplaySettings",
          "description": "Display toggles and map style for the current viewer state.",
          "x-flatbuffer-type": "VSTDisplaySettings"
        },
        "FOCUSED_REFERENCE_ID": {
          "type": "string",
          "description": "Reference id of the currently focused scenario object.",
          "x-flatbuffer-type": "string"
        },
        "FOCUSED_REFERENCE_INDEX": {
          "type": "integer",
          "minimum": -2147483648,
          "maximum": 2147483647,
          "description": "Zero-based focused reference index, or -1 when no index is focused.",
          "x-flatbuffer-type": "int",
          "x-flatbuffer-default": "-1"
        }
      },
      "additionalProperties": false
    }
  },
  "$ref": "#/definitions/VST",
  "x-flatbuffer-root-type": "VST",
  "x-flatbuffer-file-identifier": "$VST"
}