        "TARGET_VALUE": {
          "type": "number",
          "x-flatbuffer-type": "double"
        },
        "ACCURACY": {
          "type": "number",
          "x-flatbuffer-type": "double"
        },
        "MAX_ITERATIONS": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4294967295,
          "x-flatbuffer-type": "uint32"
        },
        "TRACE_ID": {
          "type": "string",
          "x-flatbuffer-type": "string"
