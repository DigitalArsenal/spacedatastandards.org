{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "definitions": {
    "numOperationCode": {
      "type": "string",
      "enum": [
        "UNKNOWN",
        "NEWTON_RAPHSON",
        "LINEAR_INTERPOLATION",
        "BILINEAR_INTERPOLATION",
        "GAUSS_MARKOV_SEQUENCE"
      ],
      "x-flatbuffer-type": "enum",
      "x-flatbuffer-enum-type": "byte",
      "x-flatbuffer-enum-values": {
        "UNKNOWN": {
          "value": 0
        },
        "NEWTON_RAPHSON": {
          "value": 1,
          "description": "Solve for a scalar root using Newton-Raphson iteration."
        },
        "LINEAR_INTERPOLATION": {
          "value": 2,
          "description": "Linearly interpolate one scalar between two scalar samples."
        },
        "BILINEAR_INTERPOLATION": {
          "value": 3,
          "description": "Bilinearly interpolate one scalar from four rectangular-corner samples."
        },
        "GAUSS_MARKOV_SEQUENCE": {
          "value": 4,
          "description": "Generate a bounded Gauss-Markov random sequence and summary statistics."
        }
      }
    },
    "numFunctionCode": {
      "type": "string",
      "enum": [
        "UNKNOWN",
        "QUADRATIC_MINUS_CONSTANT"
      ],
      "x-flatbuffer-type": "enum",
      "x-flatbuffer-enum-type": "byte",
      "x-flatbuffer-enum-values": {
        "UNKNOWN": {
          "value": 0
        },
        "QUADRATIC_MINUS_CONSTANT": {
          "value": 1,
          "description": "f(x) = x * x - TARGET_VALUE, with derivative f'(x) = 2 * x."
        }
      }
    },
    "numResultStatus": {
      "type": "string",
      "enum": [
        "OK",
        "INVALID_INPUT",
        "UNSUPPORTED_OPERATION",
        "DID_NOT_CONVERGE"
      ],
      "x-flatbuffer-type": "enum",
      "x-flatbuffer-enum-type": "byte",
      "x-flatbuffer-enum-values": {
        "OK": {
          "value": 0,
          "description": "Operation completed."
        },
        "INVALID_INPUT": {
          "value": 1,
          "description": "Request fields are missing, non-finite, or numerically invalid."
        },
        "UNSUPPORTED_OPERATION": {
          "value": 2,
          "description": "The requested operation or function is not supported."
        },
        "DID_NOT_CONVERGE": {
          "value": 3,
          "description": "Iteration did not reach ACCURACY within MAX_ITERATIONS."
        }
      }
    },
    "numDiscretizeRoundDirection": {
      "type": "string",
      "enum": [
        "TO_ZERO",
        "FROM_ZERO",
        "NEAR"
      ],
      "x-flatbuffer-type": "enum",
      "x-flatbuffer-enum-type": "byte",
      "x-flatbuffer-enum-values": {
        "TO_ZERO": {
          "value": 0,
          "description": "Round magnitude toward zero before restoring sign."
        },
        "FROM_ZERO": {
          "value": 1,
          "description": "Round magnitude away from zero before restoring sign."
        },
        "NEAR": {
          "value": 2,
          "description": "Round magnitude to the nearest least-significant-bit multiple before restoring sign."
        }
      }
    },
