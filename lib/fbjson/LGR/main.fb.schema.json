{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "definitions": {
    "licensingWrappedKeyAlgorithm": {
      "type": "string",
      "enum": [
        "X25519_HKDF_SHA256_AES_256_GCM"
      ],
      "x-flatbuffer-type": "enum",
      "x-flatbuffer-enum-type": "byte",
      "x-flatbuffer-enum-values": {
        "X25519_HKDF_SHA256_AES_256_GCM": {
          "value": 0
        }
      }
    },
    "LWK": {
      "type": "object",
      "description": "Wrapped module content key",
      "properties": {
        "REQUEST_ID": {
          "type": "string",
          "description": "Unique request identifier",
          "x-flatbuffer-type": "string",
          "x-flatbuffer-required": true
        },
        "MODULE_ID": {
          "type": "string",
          "description": "Canonical module identifier",
          "x-flatbuffer-type": "string",
          "x-flatbuffer-required": true
        },
        "MODULE_VERSION": {
          "type": "string",
          "description": "Optional module version",
          "x-flatbuffer-type": "string"
        },
        "CONTENT_KEY_ID": {
          "type": "string",
          "description": "Provider-local content key identifier",
          "x-flatbuffer-type": "string"
        },
        "RECIPIENT_KEY_ID": {
          "type": "string",
          "description": "Recipient key identifier or fingerprint",
          "x-flatbuffer-type": "string"
        },
        "ALGORITHM": {
          "$ref": "#/definitions/licensingWrappedKeyAlgorithm",
          "description": "Wrapped-key algorithm",
          "x-flatbuffer-type": "enum",
          "x-flatbuffer-enum-type": "byte",
          "x-flatbuffer-enum-values": {
            "X25519_HKDF_SHA256_AES_256_GCM": {
              "value": 0
            }
          }
        },
        "REQUESTER_EPHEMERAL_PUBKEY": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0,
            "maximum": 255
          },
          "description": "Requester ephemeral X25519 public key",
          "x-flatbuffer-type": "[ubyte]"
        },
        "PROVIDER_EPHEMERAL_PUBKEY": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0,
            "maximum": 255
          },
          "description": "Provider ephemeral X25519 public key",
          "x-flatbuffer-type": "[ubyte]"
        },
        "HKDF_SALT": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0,
            "maximum": 255
          },
          "description": "HKDF salt",
          "x-flatbuffer-type": "[ubyte]"
        },
        "IV": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0,
            "maximum": 255
          },
          "description": "AES-GCM IV",
          "x-flatbuffer-type": "[ubyte]"
        },
        "CIPHERTEXT": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0,
            "maximum": 255
          },
          "description": "Wrapped key ciphertext",
          "x-flatbuffer-type": "[ubyte]"
        },
        "TAG": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0,
            "maximum": 255
          },
          "description": "AES-GCM authentication tag",
          "x-flatbuffer-type": "[ubyte]"
        },
        "EXPIRES_AT": {
          "type": "integer",
          "minimum": 0,
          "maximum": 18446744073709551615,
          "description": "Envelope expiration time in milliseconds since epoch",
          "x-flatbuffer-type": "uint64"
        }
      },
      "required": [
        "REQUEST_ID",
        "MODULE_ID"
      ],
      "additionalProperties": false
    }
  },
  "$ref": "#/definitions/LWK",
  "x-flatbuffer-root-type": "LGR",
  "x-flatbuffer-file-identifier": "$LGR"
}