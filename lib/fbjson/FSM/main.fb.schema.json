        "STATE": {
          "$ref": "#/definitions/fieldStreamValueStateCategory",
          "x-flatbuffer-type": "enum",
          "x-flatbuffer-enum-type": "byte",
          "x-flatbuffer-enum-values": {
            "Public": {
              "value": 0
            },
            "Encrypted": {
              "value": 1
            },
            "Redacted": {
              "value": 2
            },
            "Unavailable": {
              "value": 3
            }
          },
          "x-flatbuffer-default": "Unavailable"
        },
        "ENCODING": {
          "$ref": "#/definitions/fieldStreamValueEncodingCategory",
          "x-flatbuffer-type": "enum",
          "x-flatbuffer-enum-type": "byte",
          "x-flatbuffer-enum-values": {
            "Bytes": {
              "value": 0
