      "x-flatbuffer-enum-type": "byte",
      "x-flatbuffer-enum-values": {
        "Public": {
          "value": 0
        },
        "Encrypted": {
          "value": 1
        },
        "Redacted": {
          "value": 2
        },
        "Unavailable": {
          "value": 3
        }
      }
    },
    "fieldStreamValueEncodingCategory": {
      "type": "string",
      "enum": [
        "Bytes",
        "JsonUtf8",
        "FlatBuffer",
        "TextUtf8"
      ],
      "x-flatbuffer-type": "enum",
