        "LEAP_SECOND_DATA_REQUIRED": {
          "value": 3,
          "description": "Conversion requires leap-second data that was not available."
        },
        "EOP_DATA_REQUIRED": {
          "value": 4,
          "description": "Conversion requires Earth-orientation data that was not available."
        },
        "OUT_OF_RANGE": {
          "value": 5,
          "description": "Requested instant is outside the supported conversion range."
