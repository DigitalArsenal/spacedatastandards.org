        "UNSEGMENTED": {
          "value": 1,
          "description": "CCSDS Unsegmented Time Code (CUC)."
        },
        "DAY_SEGMENTED": {
          "value": 2,
          "description": "CCSDS Day Segmented Time Code (CDS)."
        },
        "CALENDAR_SEGMENTED": {
          "value": 3,
          "description": "CCSDS Calendar Segmented Time Code (CCS)."
        }
      }
    },
    "timConversionStatus": {
      "type": "string",
      "enum": [
        "OK",
        "INVALID_INPUT",
        "UNSUPPORTED_TIME_SYSTEM",
        "LEAP_SECOND_DATA_REQUIRED",
        "EOP_DATA_REQUIRED",
        "OUT_OF_RANGE"
      ],
      "x-flatbuffer-type": "enum",
      "x-flatbuffer-enum-type": "byte",
      "x-flatbuffer-enum-values": {
        "OK": {
          "value": 0,
          "description": "Conversion completed."
        },
        "INVALID_INPUT": {
          "value": 1,
          "description": "Input epoch or requested representation is invalid."
        },
        "UNSUPPORTED_TIME_SYSTEM": {
          "value": 2,
          "description": "Requested source or target time system is not supported."
