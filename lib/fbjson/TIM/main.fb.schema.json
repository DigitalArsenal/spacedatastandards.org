    "TIMCcsdsTimeCode": {
      "type": "object",
      "description": "CCSDS time-code payload and preamble metadata.",
      "properties": {
        "CODE_KIND": {
          "$ref": "#/definitions/timCcsdsTimeCodeKind",
          "description": "CCSDS time-code family.",
          "x-flatbuffer-type": "enum",
          "x-flatbuffer-enum-type": "byte",
          "x-flatbuffer-enum-values": {
            "NONE": {
              "value": 0,
              "description": "No CCSDS time code selected."
