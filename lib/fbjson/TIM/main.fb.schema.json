            },
            "DAY_SEGMENTED": {
              "value": 2,
              "description": "CCSDS Day Segmented Time Code (CDS)."
            },
            "CALENDAR_SEGMENTED": {
              "value": 3,
              "description": "CCSDS Calendar Segmented Time Code (CCS)."
            }
          }
        },
        "PREAMBLE_FIELD1": {
          "type": "integer",
          "minimum": 0,
          "maximum": 255,
          "description": "First CCSDS preamble field octet.",
          "x-flatbuffer-type": "ubyte"
        },
        "PREAMBLE_FIELD2": {
          "type": "integer",
          "minimum": 0,
          "maximum": 255,
          "description": "Second CCSDS preamble field octet; ignored when not signaled by preamble 1.",
          "x-flatbuffer-type": "ubyte"
