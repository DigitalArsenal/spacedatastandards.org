{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "definitions": {
    "timingStandard": {
      "type": "string",
      "enum": [
        "GMST",
        "GPS",
        "MET",
        "MRT",
        "SCLK",
        "TAI",
        "TCB",
        "TDB",
        "TCG",
        "TT",
        "UT1",
        "UTC",
        "GLONASS",
        "GST",
        "QZSS",
        "BDT",
        "NAVIC",
        "SBAS"
