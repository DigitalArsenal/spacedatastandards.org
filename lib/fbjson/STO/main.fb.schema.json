{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "definitions": {
    "settlementMechanism": {
      "type": "string",
      "enum": [
        "NativeTransfer",
        "Erc20Transfer",
        "EthSplitter",
        "SolSplitter",
        "DirectAddress"
      ],
      "x-flatbuffer-type": "enum",
      "x-flatbuffer-enum-type": "byte",
      "x-flatbuffer-enum-values": {
        "NativeTransfer": {
          "value": 0,
          "description": "Native-asset transfer to a plain address (no split contract)"
        },
        "Erc20Transfer": {
          "value": 1,
          "description": "ERC-20 / SPL token transfer to a plain address"
        },
        "EthSplitter": {
          "value": 2,
          "description": "0xSplits-style splitter contract on an EVM chain"
        },
        "SolSplitter": {
          "value": 3,
          "description": "Splitter program on Solana"
        },
        "DirectAddress": {
          "value": 4,
          "description": "Direct address payout (e.g. Bitcoin); split settled off-contract"
        }
      }
    },
    "memoBindingScheme": {
      "type": "string",
      "enum": [
        "NoMemo",
        "TxData",
        "SolMemo",
        "OpReturn"
      ],
      "x-flatbuffer-type": "enum",
      "x-flatbuffer-enum-type": "byte",
      "x-flatbuffer-enum-values": {
        "NoMemo": {
          "value": 0,
          "description": "No on-chain memo binding"
        },
        "TxData": {
          "value": 1,
          "description": "Bound in EVM transaction calldata"
        },
        "SolMemo": {
          "value": 2,
          "description": "Solana memo program instruction"
        },
        "OpReturn": {
          "value": 3,
          "description": "Bitcoin OP_RETURN output"
        }
      }
    },
    "SplitRecipient": {
      "type": "object",
      "description": "Recipient of an on-chain revenue split. The identity binds to an `$EPM`\nvia CHAIN_PROOFS so a payout address is provably the recipient's.",
      "properties": {
        "EPM_CID": {
          "type": "string",
          "description": "IPFS CID of the recipient's Entity Profile Message (`$EPM`)",
          "x-flatbuffer-type": "string"
        },
        "CHAIN": {
          "type": "string",
          "description": "Settlement chain, e.g. \"ethereum\", \"solana\", \"bitcoin\"",
          "x-flatbuffer-type": "string"
        },
        "ADDRESS": {
          "type": "string",
          "description": "On-chain payout address (EVM 0x / SOL base58 / BTC address)",
          "x-flatbuffer-type": "string"
        },
        "XPUB": {
          "type": "string",
          "description": "Account xpub the address derives from",
          "x-flatbuffer-type": "string"
        }
      },
      "additionalProperties": false
    },
    "SCX": {
      "type": "object",
      "description": "Chain Settlement / Smart-Contract Descriptor. The forward description of the\nexact established splitter contract/program a buyer's wallet targets so\npayment and platform commission settle atomically on-chain. Referenced by\n`$CMT.CONTRACTS` and echoed into a store `checkout` quote. Commission is\nrealized by the splitter contract itself when the buyer pays it; there is no\noff-chain or manual settlement step.",
      "properties": {
        "CHAIN": {
          "type": "string",
          "description": "Settlement chain identifier, e.g. \"ethereum\", \"solana\", \"bitcoin\"\n(matches `$PUR.PAYMENT_CHAIN`)",
          "x-flatbuffer-type": "string",
          "x-flatbuffer-required": true
        },
        "CHAIN_ID": {
          "type": "integer",
          "minimum": 0,
          "maximum": 18446744073709551615,
          "description": "EVM chainId; 0 for non-EVM chains",
          "x-flatbuffer-type": "uint64"
        },
        "SETTLEMENT_KIND": {
          "$ref": "#/definitions/settlementMechanism",
          "description": "On-chain settlement mechanism",
          "x-flatbuffer-type": "enum",
          "x-flatbuffer-enum-type": "byte",
          "x-flatbuffer-enum-values": {
            "NativeTransfer": {
              "value": 0,
              "description": "Native-asset transfer to a plain address (no split contract)"
            },
            "Erc20Transfer": {
              "value": 1,
              "description": "ERC-20 / SPL token transfer to a plain address"
            },
            "EthSplitter": {
              "value": 2,
              "description": "0xSplits-style splitter contract on an EVM chain"
            },
            "SolSplitter": {
              "value": 3,
              "description": "Splitter program on Solana"
            },
            "DirectAddress": {
              "value": 4,
              "description": "Direct address payout (e.g. Bitcoin); split settled off-contract"
            }
          }
        },
        "SPLITTER_STANDARD": {
          "type": "string",
          "description": "Established split standard id, e.g. \"0xsplits.v2\" (ETH) or the SOL\nsplitter program name. An audited off-the-shelf standard, not a custom\ncontract.",
          "x-flatbuffer-type": "string"
        },
        "SPLITTER_ADDRESS": {
          "type": "string",
          "description": "Deployed splitter contract address (ETH) or splitter program id (SOL) the\nbuyer's payment routes into",
          "x-flatbuffer-type": "string"
        },
        "SPLIT_CONFIG_ID": {
          "type": "string",
          "description": "The specific split configuration (recipient set + basis points) registered\nwith the splitter",
          "x-flatbuffer-type": "string"
        },
        "TOKEN_ADDRESS": {
          "type": "string",
          "description": "ERC-20 / SPL mint address for stablecoin settlement; empty = native asset",
          "x-flatbuffer-type": "string"
        },
        "TOKEN_SYMBOL": {
          "type": "string",
          "description": "Token symbol, e.g. \"USDC\"",
          "x-flatbuffer-type": "string"
        },
        "TOKEN_DECIMALS": {
          "type": "integer",
          "minimum": 0,
          "maximum": 255,
          "description": "Token decimals, e.g. 6 for USDC",
          "x-flatbuffer-type": "uint8"
        },
        "SPLIT_RECIPIENTS": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/SplitRecipient"
          },
          "description": "The recipient set the split configuration encodes (platform + publisher\u2026),\nmirrored here for independent verification",
          "x-flatbuffer-type": "[SplitRecipient]"
        },
        "MIN_CONFIRMATIONS": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4294967295,
          "description": "Confirmations required before the payment is accepted",
          "x-flatbuffer-type": "uint32"
        },
        "MEMO_SCHEME": {
          "$ref": "#/definitions/memoBindingScheme",
          "description": "How the order reference is bound on-chain for replay-safe matching",
          "x-flatbuffer-type": "enum",
          "x-flatbuffer-enum-type": "byte",
          "x-flatbuffer-enum-values": {
            "NoMemo": {
              "value": 0,
              "description": "No on-chain memo binding"
            },
            "TxData": {
              "value": 1,
              "description": "Bound in EVM transaction calldata"
            },
            "SolMemo": {
              "value": 2,
              "description": "Solana memo program instruction"
            },
            "OpReturn": {
              "value": 3,
              "description": "Bitcoin OP_RETURN output"
            }
          }
        }
      },
      "required": [
        "CHAIN"
      ],
      "additionalProperties": false
    },
    "commissionScope": {
      "type": "integer",
      "x-flatbuffer-type": "enum",
      "x-flatbuffer-enum-type": "byte",
      "description": "What a set of commission terms applies to.",
      "enum": [
        0,
        1,
        2
      ],
      "x-flatbuffer-enum-values": {
        "Listing": {
          "value": 0,
          "description": "A single listing"
        },
        "Store": {
          "value": 1,
          "description": "A whole store's default terms"
        },
        "Publisher": {
          "value": 2,
          "description": "A publisher's default terms"
        }
      }
    },
    "commissionEnforcement": {
      "type": "integer",
      "x-flatbuffer-type": "enum",
      "x-flatbuffer-enum-type": "byte",
      "description": "How the commission split is enforced.",
      "enum": [
        0,
        1
      ],
      "x-flatbuffer-enum-values": {
        "SplitterContract": {
          "value": 0,
          "description": "Enforced on-chain by an established splitter contract/program: the split executes when the buyer pays the splitter. No off-chain or manual settlement \u2014 the platform collects commission purely by the buyer's payment routing through the splitter contract."
        },
        "ProviderAttested": {
          "value": 1,
          "description": "Provider-attested off-contract split, used only where no splitter exists (e.g. BTC / DirectAddress)"
        }
      }
    },
    "splitRole": {
      "type": "integer",
      "x-flatbuffer-type": "enum",
      "x-flatbuffer-enum-type": "byte",
      "description": "Role a split recipient plays in the revenue division.",
      "enum": [
        0,
        1,
        2,
        3
      ],
      "x-flatbuffer-enum-values": {
        "Publisher": {
          "value": 0,
          "description": "The module/flow publisher (vendor)"
        },
        "Platform": {
          "value": 1,
          "description": "The store operator platform (e.g. SpaceAware) \u2014 the commission recipient"
        },
        "Referrer": {
          "value": 2,
          "description": "A referrer who drove the sale"
        },
        "Charity": {
          "value": 3,
          "description": "A charitable recipient"
        }
      }
    },
    "RevenueSplit": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "RECIPIENT": {
          "$ref": "#/definitions/SplitRecipient",
          "description": "The payout recipient",
          "x-flatbuffer-type": "SplitRecipient"
        },
        "BPS": {
          "type": "integer",
          "description": "commission sum to 10000",
          "x-flatbuffer-type": "uint16"
        },
        "ROLE": {
          "$ref": "#/definitions/splitRole",
          "description": "The role this recipient plays",
          "x-flatbuffer-type": "enum",
          "x-flatbuffer-enum-type": "byte",
          "x-flatbuffer-enum-values": {
            "Publisher": {
              "value": 0,
              "description": "The module/flow publisher (vendor)"
            },
            "Platform": {
              "value": 1,
              "description": "The store operator platform (e.g. SpaceAware) \u2014 the commission recipient"
            },
            "Referrer": {
              "value": 2,
              "description": "A referrer who drove the sale"
            },
            "Charity": {
              "value": 3,
              "description": "A charitable recipient"
            }
          }
        }
      },
      "description": "One recipient's share of a sale, expressed in basis points."
    },
    "CMT": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "TERMS_ID": {
          "type": "string",
          "description": "Stable terms identifier, referenced by `$PUR`/`$ACL`/listings",
          "x-flatbuffer-type": "string",
          "x-flatbuffer-required": true
        },
        "SCOPE": {
          "$ref": "#/definitions/commissionScope",
          "description": "What these terms cover",
          "x-flatbuffer-type": "enum",
          "x-flatbuffer-enum-type": "byte",
          "x-flatbuffer-enum-values": {
            "Listing": {
              "value": 0,
              "description": "A single listing"
            },
            "Store": {
              "value": 1,
              "description": "A whole store's default terms"
            },
            "Publisher": {
              "value": 2,
              "description": "A publisher's default terms"
            }
          }
        },
        "TARGET_ID": {
          "type": "string",
          "description": "The `$PLG.PLUGIN_ID` / store id / publisher xpub the terms apply to",
          "x-flatbuffer-type": "string"
        },
        "COMMISSION_BPS": {
          "type": "integer",
          "description": "Platform commission in basis points (e.g. 500 = 5%)",
          "x-flatbuffer-type": "uint16"
        },
        "SPLITS": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/RevenueSplit"
          },
          "description": "Recipient splits; each in basis points, summing with the commission to 10000",
          "x-flatbuffer-type": "[RevenueSplit]"
        },
        "PLATFORM_RECIPIENT": {
          "$ref": "#/definitions/SplitRecipient",
          "description": "The platform's per-chain payout identity (the commission recipient)",
          "x-flatbuffer-type": "SplitRecipient"
        },
        "ENFORCEMENT": {
          "$ref": "#/definitions/commissionEnforcement",
          "description": "How the split is enforced (on-chain splitter vs provider-attested)",
          "x-flatbuffer-type": "enum",
          "x-flatbuffer-enum-type": "byte",
          "x-flatbuffer-enum-values": {
            "SplitterContract": {
              "value": 0,
              "description": "Enforced on-chain by an established splitter contract/program: the split executes when the buyer pays the splitter. No off-chain or manual settlement \u2014 the platform collects commission purely by the buyer's payment routing through the splitter contract."
            },
            "ProviderAttested": {
              "value": 1,
              "description": "Provider-attested off-contract split, used only where no splitter exists (e.g. BTC / DirectAddress)"
            }
          }
        },
        "CONTRACTS": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/SCX"
          },
          "description": "one per accepted chain/asset",
          "x-flatbuffer-type": "[SCX]"
        },
        "EFFECTIVE_AT": {
          "type": "integer",
          "description": "Unix ms when these terms take effect",
          "x-flatbuffer-type": "uint64"
        },
        "EXPIRES_AT": {
          "type": "integer",
          "description": "Unix ms when these terms expire, or 0 for no expiry",
          "x-flatbuffer-type": "uint64"
        },
        "SIGNATURE": {
          "type": "array",
          "items": {
            "type": "integer"
          },
          "description": "Ed25519 signature by the store operator `$EPM`",
          "x-flatbuffer-type": "[ubyte]"
        }
      },
      "description": "Commission Terms / Revenue Split. Binds a listing, store, or publisher to a platform commission and the on-chain split that enforces it. This record makes \"the platform earns on every transaction\" auditable and portable across store deployments. Commission is realized purely by the buyer's payment routing through the on-chain splitter contract described in CONTRACTS \u2014 never by a manual or off-chain settlement step.",
      "required": [
        "TERMS_ID"
      ]
    },
    "STOModuleRef": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "PLUGIN_ID": {
          "type": "string",
          "description": "`$PLG.PLUGIN_ID` of the store module",
          "x-flatbuffer-type": "string"
        },
        "CONTENT_HASH": {
          "type": "string",
          "description": "Content hash of the (encrypted) store module artifact",
          "x-flatbuffer-type": "string"
        },
        "VERSION": {
          "type": "string",
          "description": "Module version",
          "x-flatbuffer-type": "string"
        }
      },
      "description": "Reference to the store module that runs a store."
    },
    "STO": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "STORE_ID": {
          "type": "string",
          "description": "Stable store identity",
          "x-flatbuffer-type": "string",
          "x-flatbuffer-required": true
        },
        "NAME": {
          "type": "string",
          "description": "Display name",
          "x-flatbuffer-type": "string"
        },
        "DESCRIPTION": {
          "type": "string",
          "description": "Display description",
          "x-flatbuffer-type": "string"
        },
        "OPERATOR_EPM_CID": {
          "type": "string",
          "description": "IPFS CID of the store operator's `$EPM`",
          "x-flatbuffer-type": "string"
        },
        "STORE_MODULE": {
          "$ref": "#/definitions/STOModuleRef",
          "description": "The (encrypted) store MODULE that runs this store",
          "x-flatbuffer-type": "STOModuleRef"
        },
        "APP_ID": {
          "type": "string",
          "description": "Optional `$APP.ID` when the store ships a UI app",
          "x-flatbuffer-type": "string"
        },
        "IS_OFFICIAL": {
          "type": "boolean",
          "description": "platform's well-known signing key",
          "x-flatbuffer-type": "bool"
        },
        "COMMISSION_TERMS": {
          "$ref": "#/definitions/CMT",
          "description": "Store-default commission terms, embedded",
          "x-flatbuffer-type": "CMT"
        },
        "COMMISSION_TERMS_ID": {
          "type": "string",
          "description": "Alternative reference to store-default terms by `$CMT.TERMS_ID`",
          "x-flatbuffer-type": "string"
        },
        "ACCEPTED_CHAINS": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/SCX"
          },
          "description": "Chains/tokens this store accepts, each with its splitter settlement",
          "x-flatbuffer-type": "[SCX]"
        },
        "CATALOG_ROOT_CID": {
          "type": "string",
          "description": "IPFS CID of the store's catalog (a `$REC` of `$PLG`/`$STF` listings)",
          "x-flatbuffer-type": "string"
        },
        "DISCOVERY_KEY": {
          "type": "string",
          "description": "libp2p advertise/discovery key for reachability",
          "x-flatbuffer-type": "string"
        },
        "PROTOCOL_ID": {
          "type": "string",
          "description": "libp2p protocol id the store answers on",
          "x-flatbuffer-type": "string"
        },
        "SIGNATURE": {
          "type": "array",
          "items": {
            "type": "integer"
          },
          "description": "Ed25519 signature by the operator `$EPM`",
          "x-flatbuffer-type": "[ubyte]"
        }
      },
      "description": "Store Descriptor \u2014 storefront identity",
      "required": [
        "STORE_ID"
      ]
    }
  },
  "$ref": "#/definitions/STO",
  "x-flatbuffer-root-type": "STO",
  "x-flatbuffer-file-identifier": "$STO"
}