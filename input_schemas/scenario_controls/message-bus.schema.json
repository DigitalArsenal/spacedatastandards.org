    "ScenarioAssetsChangedMessage": {
      "type": "object",
      "description": "Outgoing message payload (wrapped as { ScenarioAssetsChanged: ... }) when the user adds or removes satellites or ground sites in the active scenario.",
      "properties": {
        "AddedSatellites": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SceneReference"
          }
        },
        "AddedGroundSites": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SceneReference"
          }
        },
        "RemovedSatellites": {
