          },
          "minItems": 3,
          "maxItems": 3
        },
        "Rx": {
          "type": "number"
        },
        "Ry": {
          "type": "number"
        },
        "Rz": {
          "type": "number"
        },
        "Vx": {
          "type": "number"
        },
        "Vy": {
          "type": "number"
        },
        "Vz": {
          "type": "number"
        },
        "Epoch": {
          "$ref": "#/$defs/DateTimeString"
        },
        "Source": {
          "type": "string"
        }
      }
    },
    "ViewConeParameters": {
      "type": "object",
      "properties": {
        "MinElevation": {
          "type": "number"
        },
        "MaxElevation": {
          "type": "number"
        },
        "MinAzimuth": {
