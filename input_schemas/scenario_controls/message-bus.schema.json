        },
        "MaxAzimuth": {
          "type": "number"
        },
        "Range": {
          "type": "number"
        },
        "HalfAngle": {
          "type": [
            "number",
            "null"
          ]
        },
        "DynamicRange": {
          "type": "string"
        }
      }
    },
    "SunAdvantageTarget": {
      "type": "object",
      "properties": {
